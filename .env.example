# Copy to .env.local for local testing (with `vercel dev`), and set the same
# values in Vercel → Project → Settings → Environment Variables for production.

# The Google Workspace mailbox that sends the mail (the authenticated account).
SMTP_USER=claudia@auroraprogramsolutions.com

# A Google App Password (16 characters, no spaces) — NOT her normal password.
# Generate at: myaccount.google.com → Security → 2-Step Verification → App passwords
SMTP_PASS=your-16-char-app-password

# Where inquiries are delivered. Optional — defaults to SMTP_USER if omitted.
CONTACT_TO=claudia@auroraprogramsolutions.com
